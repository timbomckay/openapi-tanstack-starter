{
  "name": "openapi-tanstack-starter",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "api:generate": "openapi-ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-form": "^1.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-router": "^1.0.0",
    "@tanstack/react-table": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.94.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/query-devtools": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "@tanstack/react-router-devtools": "^1.0.0",
    "@tanstack/router-plugin": "^1.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.0.0",
    "shadcn": "^4.1.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxfmt --write",
      "oxlint"
    ],
    "*.{js,mjs,cjs,json,css,html}": "oxfmt --write"
  }
}
